{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "apiarylens-family",
  // CF-001: pin the ApiaryLens Cloudflare account so deploys fail loudly
  // instead of following whatever account the ambient token resolves to.
  "account_id": "5d8be56e19f1f800b8e482a449472dd9",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "send_metrics": false,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "apiarylens-family",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "apiarylens-family-media",
    },
  ],
  "observability": { "enabled": false },
  "env": {
    "uat": {
      "name": "apiarylens-family-uat",
      "workers_dev": true,
      "preview_urls": false,
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "apiarylens-family-uat",
          "database_id": "8e33a873-9665-4455-a480-44e67f6ad16c",
          "migrations_dir": "migrations",
        },
      ],
      "r2_buckets": [
        {
          "binding": "MEDIA",
          "bucket_name": "apiarylens-family-media-uat",
        },
      ],
      "observability": { "enabled": false },
    },
    "production": {
      "name": "apiarylens-family-production",
      "workers_dev": false,
      "preview_urls": false,
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "apiarylens-family-production",
          "database_id": "94d019ec-854d-488f-8dd6-41ecea1044d0",
          "migrations_dir": "migrations",
        },
      ],
      "r2_buckets": [
        {
          "binding": "MEDIA",
          "bucket_name": "apiarylens-family-media-production",
        },
      ],
      "observability": { "enabled": false },
    },
  },
}
