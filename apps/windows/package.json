{
  "name": "@apiarylens/windows",
  "version": "0.1.0-preview.2",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "pnpm --filter @apiarylens/contracts build && pnpm --filter @apiarylens/database build && pnpm --filter @apiarylens/media build && pnpm --filter @apiarylens/server build && pnpm --filter @apiarylens/web build && tsc -p tsconfig.build.json && node -e \"require('node:fs').copyFileSync('src/preload.cjs','dist/preload.cjs')\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "pnpm build && electron .",
    "lint": "tsc -p tsconfig.json --noEmit",
    "package:windows": "node ../../scripts/build-windows-package.mjs",
    "start": "electron .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@apiarylens/contracts": "workspace:*",
    "@apiarylens/database": "workspace:*",
    "@apiarylens/media": "workspace:*",
    "@apiarylens/server": "workspace:*",
    "@hono/node-server": "catalog:",
    "electron-squirrel-startup": "1.0.1"
  },
  "devDependencies": {
    "@electron/packager": "18.4.4",
    "@types/node": "catalog:",
    "electron": "43.1.1",
    "electron-winstaller": "5.4.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
