# Use localhost only for same-device evaluation. Caddy creates a local HTTPS certificate.
# For LAN or internet access, set a real DNS name that resolves to this host.
APIARYLENS_SITE_ADDRESS=localhost
APIARYLENS_VERSION=0.1.0-preview.6
APIARYLENS_SOURCE_COMMIT=development
APIARYLENS_BUILD_TIME=development
APIARYLENS_ARTIFACT_IDENTITY=ApiaryLens@0.1.0-preview.6+development
APIARYLENS_HTTP_PORT=80
APIARYLENS_HTTPS_PORT=443

# Required for public ACME certificates; not required for localhost.
