{
  "name": "apiarylens",
  "version": "0.1.0-preview.3",
  "private": true,
  "description": "Open-source, self-hosted, offline-first apiary management",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present run clean",
    "dev": "pnpm --filter @apiarylens/server dev",
    "dev:web": "pnpm --filter @apiarylens/web dev",
    "dev:worker": "pnpm --filter @apiarylens/worker dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "test:e2e": "pnpm --filter @apiarylens/e2e test",
    "release:artifacts": "node scripts/build-release-artifacts.mjs",
    "release:supply-chain": "node scripts/build-supply-chain.mjs",
    "release:windows": "node scripts/build-windows-package.mjs release/artifacts/windows",
    "release:reproducible": "node scripts/verify-reproducible-build.mjs",
    "release:verify": "node scripts/verify-release-identity.mjs && node scripts/verify-release-supply-chain.mjs",
    "security:secrets": "node scripts/scan-secrets.mjs",
    "docs:check": "node scripts/check-doc-links.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && node scripts/test-backup-restore.mjs",
    "version:check": "node scripts/verify-release-identity.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "prettier": "^3.8.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
